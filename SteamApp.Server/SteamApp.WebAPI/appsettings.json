{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "localhost;127.0.0.1;wzjw33gc-4200.euw.devtunnels.ms",

  "Authentication": {
    "AllowRegistration": false,
    "AdminEmails": []
  },

  "Database": {
    "EnsureIdentitySchemaOnStartup": false
  },

  "InternalApi": {
    //"BaseUrl": "http://127.0.0.1:8080/",
    "BaseUrl": "https://localhost:7273/"
  },

  "TransientRetryPolicy": {
    "MaxAttempts": 3,
    "BaseDelayMilliseconds": 200,
    "MaxDelayMilliseconds": 2000,
    "UseJitter": true
  },

  "Cryptography": {
    "Argon2MemorySizeKb": 65536,
    "Argon2Iterations": 3,
    "Argon2DegreeOfParallelism": 1,
    "Argon2SaltSizeBytes": 16,
    "Argon2HashSizeBytes": 32
  },

  "Workers": {
    "WishlistCheck": {
      "Enabled": false,
      "Interval": "00:00:15",
      "DisplayName": "WishlistCheck Worker"
    }
  }
}

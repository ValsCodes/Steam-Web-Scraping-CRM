ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

AllowedHosts=localhost;127.0.0.1
Authentication__AllowRegistration=true
Database__EnsureIdentitySchemaOnStartup=false

ConnectionStrings__DefaultConnection=Server=steamapp-sql,1433;Database=SteamAppDb;User Id=sa;Password=Change_this_password_123!;TrustServerCertificate=True;Encrypt=True;

JwtSettings__Key=replace-with-a-random-signing-key-at-least-32-bytes-long
JwtSettings__Issuer=SteamApp
JwtSettings__Audience=SteamAppClient
JwtSettings__DurationMinutes=60

Cors__AllowedOrigins__0=http://localhost:4200

Clients__0__ClientId=steam-client
Clients__0__ClientSecret=dev-client-secret
Clients__0__AllowedScope=user
Clients__1__ClientId=steam-internal
Clients__1__ClientSecret=dev-internal-secret
Clients__1__AllowedScope=internal

Workers__WishlistCheck__Enabled=false
Workers__WishlistCheck__Interval=00:00:30
Workers__WishlistCheck__DisplayName=WishlistCheck Worker

# Optional Mailtrap configuration.
# Mailtrap__ApiToken=
# Mailtrap__SandboxID=
